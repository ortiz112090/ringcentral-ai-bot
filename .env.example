# ---- Server ----
PORT=3000
# Public base URL of this service once deployed (used to build webhook delivery address).
PUBLIC_BASE_URL=https://your-app.onrender.com

# ---- RingCentral ----
# Use the JWT (server-to-server) auth flow. Create a JWT credential in the RingCentral
# developer console for your app and paste it here.
RINGCENTRAL_CLIENT_ID=your_ringcentral_client_id
RINGCENTRAL_CLIENT_SECRET=your_ringcentral_client_secret
# Production: https://platform.ringcentral.com  |  Sandbox: https://platform.devtest.ringcentral.com
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
RINGCENTRAL_JWT=your_ringcentral_jwt
# Extension or phone number the bot transfers to when escalating to a human.
ESCALATION_QUEUE_EXTENSION=101
# Optional: secret used to verify inbound webhook notifications (RingCentral "verificationToken").
RINGCENTRAL_WEBHOOK_VERIFICATION_TOKEN=change_me_to_a_random_string

# ---- Twilio (voice path: Media Streams ↔ OpenAI Realtime) ----
# Voice transport for this bot: 'ringcentral' (default) or 'twilio'. When 'twilio',
# RingCentral voice-answering is skipped (RC still handles SMS); calls to the RC
# number must be FORWARDED (in RC admin) to TWILIO_NUMBER. Normally set per-bot in
# the dashboard (bot_config.voice_provider); env is the primary-bot fallback.
VOICE_PROVIDER=ringcentral
# E.164 Twilio number that answers this bot's voice line (bot_config.twilio_number).
TWILIO_NUMBER=+15550000000
# E.164 number to <Dial> when escalating a Twilio call to a human
# (bot_config.escalation_number). Twilio cannot dial RC extensions.
TWILIO_ESCALATION_NUMBER=+15551234567
# Twilio REST + webhook-signature credentials. DB-first (api_credentials provider
# 'twilio': account_sid, auth_token); these env vars are the primary-bot fallback only.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ---- OpenAI (sole AI provider: Realtime voice + chat + STT/TTS) ----
OPENAI_API_KEY=your_openai_api_key
# Chat model for the SMS text path + learning-system lesson extraction.
OPENAI_CHAT_MODEL=gpt-4o
# Realtime speech-to-speech model for LIVE phone calls. Update this one value when
# OpenAI promotes a newer realtime model (see src/config.ts realtimeModel).
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# Realtime voice. Options include: alloy, echo, shimmer, ash, ballad, coral, sage, verse.
OPENAI_REALTIME_VOICE=alloy
# Audio codec exchanged with the Realtime API. g711_ulaw (mu-law 8kHz) is telephony-native
# and avoids resampling; pcm16 (24kHz) is higher fidelity but needs transcoding for PSTN.
OPENAI_REALTIME_AUDIO_FORMAT=g711_ulaw
# STT/TTS are still used by the SMS text path and learning-system audio ingestion.
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# ---- Drop Cowboy (ringless-voicemail / RVM campaigns) ----
# Credentials for the voicemail_drops campaign engine. DB-first (api_credentials
# provider 'dropcowboy': team_id, secret, brand_id); these env vars are the
# primary-bot fallback only. Role gate: only answer_and_followup bots run RVM.
DROPCOWBOY_TEAM_ID=your_dropcowboy_team_id
DROPCOWBOY_SECRET=your_dropcowboy_secret
DROPCOWBOY_BRAND_ID=your_dropcowboy_brand_id
# Shared token for the RVM delivery-status webhook (POST /webhooks/dropcowboy/status
# ?token=...). Unset → the webhook fails closed (503). Use a long random string.
DC_WEBHOOK_TOKEN=change_me_to_a_random_string

# ---- Bot role (multi-role) ----
# Per-tenant role gate (bot_config.bot_role): answer_calls | outbound_calls |
# answer_and_followup | texting. Normally set in the dashboard; this env is the
# primary-bot fallback. Default answer_calls (inbound voice only).
BOT_ROLE=answer_calls

# ---- Supabase ----
# Project ref: hiqyfprmtipgrvwadqdb (RESUME/UNPAUSE it in the Supabase dashboard before first use)
SUPABASE_URL=https://hiqyfprmtipgrvwadqdb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Tenant identity (multi-tenant) ----
# REQUIRED. Every deployment is ONE tenant; the bot only reads/writes rows where
# bot_id = BOT_ID. Per-tenant — get this from the dashboard's Bots page. The
# primary/default bot ("Insurance Express") is the uuid below.
BOT_ID=00000000-0000-0000-0000-000000000001

# ---- Business context injected into the sales script ----
AGENT_NAME=Alex
BROKERAGE_NAME=Your Brokerage

# ---- Learning system (retrieval-based; see README "Learning System") ----
# true = embed lessons + use pgvector similarity search; false = category-match fallback.
LEARNING_USE_PGVECTOR=false
# How many approved lessons to inject into the live prompt per call.
LEARNING_RETRIEVAL_LIMIT=3
# Only used when LEARNING_USE_PGVECTOR=true (must match the vector(1536) column dims).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
