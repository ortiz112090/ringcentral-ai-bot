# ---- Server ----
PORT=3000
# Public base URL of this service once deployed (used to build webhook delivery address).
PUBLIC_BASE_URL=https://your-app.onrender.com

# ---- RingCentral ----
# Use the JWT (server-to-server) auth flow. Create a JWT credential in the RingCentral
# developer console for your app and paste it here.
RINGCENTRAL_CLIENT_ID=your_ringcentral_client_id
RINGCENTRAL_CLIENT_SECRET=your_ringcentral_client_secret
# Production: https://platform.ringcentral.com  |  Sandbox: https://platform.devtest.ringcentral.com
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
RINGCENTRAL_JWT=your_ringcentral_jwt
# Extension or phone number the bot transfers to when escalating to a human.
ESCALATION_QUEUE_EXTENSION=101
# Optional: secret used to verify inbound webhook notifications (RingCentral "verificationToken").
RINGCENTRAL_WEBHOOK_VERIFICATION_TOKEN=change_me_to_a_random_string

# ---- OpenAI (sole AI provider: Realtime voice + chat + STT/TTS) ----
OPENAI_API_KEY=your_openai_api_key
# Chat model for the SMS text path + learning-system lesson extraction.
OPENAI_CHAT_MODEL=gpt-4o
# Realtime speech-to-speech model for LIVE phone calls. Update this one value when
# OpenAI promotes a newer realtime model (see src/config.ts realtimeModel).
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# Realtime voice. Options include: alloy, echo, shimmer, ash, ballad, coral, sage, verse.
OPENAI_REALTIME_VOICE=alloy
# Audio codec exchanged with the Realtime API. g711_ulaw (mu-law 8kHz) is telephony-native
# and avoids resampling; pcm16 (24kHz) is higher fidelity but needs transcoding for PSTN.
OPENAI_REALTIME_AUDIO_FORMAT=g711_ulaw
# STT/TTS are still used by the SMS text path and learning-system audio ingestion.
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# ---- Supabase ----
# Project ref: hawjzggkndvxylzxvwvx (RESUME/UNPAUSE it in the Supabase dashboard before first use)
SUPABASE_URL=https://hawjzggkndvxylzxvwvx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Business context injected into the sales script ----
AGENT_NAME=Alex
BROKERAGE_NAME=Your Brokerage

# ---- Learning system (retrieval-based; see README "Learning System") ----
# true = embed lessons + use pgvector similarity search; false = category-match fallback.
LEARNING_USE_PGVECTOR=false
# How many approved lessons to inject into the live prompt per call.
LEARNING_RETRIEVAL_LIMIT=3
# Only used when LEARNING_USE_PGVECTOR=true (must match the vector(1536) column dims).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
