{
  "name": "ringcentral-ai-bot",
  "version": "1.0.0",
  "description": "AI voice agent that answers inbound RingCentral calls, runs an SR22 auto-insurance sales script via Claude, with OpenAI STT/TTS and Supabase logging.",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit",
    "learn:ingest": "node dist/learning/cli.js ingest",
    "learn:tag": "node dist/learning/cli.js tag",
    "learn:review": "node dist/learning/cli.js review"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@ringcentral/sdk": "^5.0.4",
    "@supabase/supabase-js": "^2.45.4",
    "express": "^4.21.1",
    "openai": "^4.67.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
